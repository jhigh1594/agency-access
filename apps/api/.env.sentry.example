# Sentry Configuration (Backend - Fastify)

# Sentry DSN (Error Tracking)
SENTRY_DSN=your-sentry-dsn-here

# Optional: Send events in development (default: false)
SENTRY_SEND_IN_DEV=false

# Optional: App version for release tracking
# APP_VERSION=1.0.0

# Sentry Source Map Upload (for production deployment)
# Generate auth token at: https://sentry.io/settings/auth-tokens/
# Requires project:releases scope
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=node

# Sentry Webhook Integration
# Generate a secure random secret: openssl rand -hex 32
# This secret is used to verify webhook signatures from Sentry
SENTRY_WEBHOOK_SECRET=your-webhook-secret-here
